# This repo runs on Linux (Virtuoso SKILL, Python tunnel). Keep LF in the
# repository and on checkout so files copied to the server have Unix line
# endings, regardless of the contributor's OS.
* text=auto eol=lf

*.il  text eol=lf
*.py  text eol=lf
*.sh  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.toml text eol=lf

*.zip binary
