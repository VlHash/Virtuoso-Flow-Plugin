{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "result.schema.json",
  "title": "VFP Simulation Result",
  "description": "Parsed simulation metrics plus constraint evaluation for one test.",
  "type": "object",
  "required": ["schema_version", "metrics"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1", "0.2"] },
    "result_id": { "type": "string" },
    "source": { "type": "string", "description": "e.g. 'spectre', 'ade', 'manual'" },
    "cellview": { "$ref": "#/$defs/cellview" },
    "test": { "type": "string" },
    "metrics": {
      "type": "object",
      "description": "Metric name -> numeric value (e.g. A0_dB, UGB_MHz, PM_deg, power_mW).",
      "additionalProperties": { "type": "number" }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "overall": { "type": "string", "enum": ["pass", "fail"] },
        "items": { "type": "array", "items": { "$ref": "#/$defs/constraint_item" } }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Label -> path of a stored artifact (log, metrics, ...).",
      "additionalProperties": { "type": "string" }
    },
    "provenance": {
      "type": "object",
      "description": "Where this result came from (schema 0.2).",
      "properties": {
        "netlist_hash": { "type": "string", "description": "Digest of the exact deck simulated." },
        "source_mode": { "type": "string", "description": "How the deck was produced, e.g. 'reuse' / 'si'." },
        "cellview": { "$ref": "#/$defs/cellview" },
        "saved_at": { "type": ["string", "null"], "description": "Cellview last-saved time (ddGetObjLastModify); null until plumbed." },
        "fingerprint": { "type": "string", "description": "Inputs fingerprint the result was keyed on." },
        "session": { "type": "string", "description": "Originating Virtuoso session_id (M8 handle)." },
        "session_fingerprint": {
          "type": "object",
          "description": "Durable identity of the producing Virtuoso, snapshotted at job.create (survives session reaping).",
          "properties": {
            "virtuoso_pid": { "type": "string" },
            "virtuoso_start": { "type": "string" },
            "display": { "type": "string" },
            "cds_lib": { "type": "string" }
          }
        }
      }
    },
    "metric_quality": {
      "type": "object",
      "description": "Qualitative tag for non-finite / sentinel metrics so a NaN never crosses as a number (schema 0.2). E.g. GM=nan -> 'unconditional', 999 dB -> 'saturated'.",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "cellview": {
      "type": "object",
      "required": ["lib", "cell", "view"],
      "properties": {
        "lib": { "type": "string" },
        "cell": { "type": "string" },
        "view": { "type": "string" }
      },
      "additionalProperties": false
    },
    "constraint_item": {
      "type": "object",
      "required": ["metric", "status"],
      "properties": {
        "metric": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "reason": { "type": "string" }
      }
    }
  }
}
