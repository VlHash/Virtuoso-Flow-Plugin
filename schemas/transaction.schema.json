{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "transaction.schema.json",
  "title": "VFP Transaction",
  "description": "Before/after record of an applied proposal, enabling rollback.",
  "type": "object",
  "required": ["schema_version", "transaction_id", "status"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "transaction_id": { "type": "string" },
    "proposal_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["applied", "failed", "rolled_back"]
    },
    "kind": {
      "type": "string",
      "enum": ["schematic_param", "layout_geom"],
      "description": "schematic_param = before/after parameter values, rolled back field-by-field (the default). layout_geom = a layout geometry edit (L4); the diff is in `geometry`, and rollback restores from the `checkpoint` view since geometry is not field-invertible."
    },
    "cellview": { "$ref": "#/$defs/cellview" },
    "before": { "type": "array", "items": { "$ref": "#/$defs/param_value" } },
    "after": { "type": "array", "items": { "$ref": "#/$defs/param_value" } },
    "geometry": {
      "$ref": "#/$defs/geometry",
      "description": "Layout geometry diff for a layout_geom transaction: shape/instance/via change records and before/after counts. The checkpoint view holds the full pre-edit state; only the compact diff is stored here."
    },
    "timestamp": { "type": "string", "description": "ISO-8601 timestamp (second-granular)" },
    "created_ts": { "type": "number", "description": "Epoch seconds; orders same-second changes precisely for the blame chain." },
    "actor": { "type": "string", "description": "Who applied/rolled back, e.g. 'agent' or 'user'." },
    "session": { "type": "string", "description": "Originating Virtuoso session_id (M8 handle)." },
    "session_fingerprint": {
      "type": "object",
      "description": "Durable identity of the applying Virtuoso, snapshotted at create.",
      "properties": {
        "virtuoso_pid": { "type": "string" },
        "virtuoso_start": { "type": "string" },
        "display": { "type": "string" },
        "cds_lib": { "type": "string" }
      }
    },
    "linked_results": {
      "type": "array",
      "items": { "type": "string", "description": "result_id" }
    },
    "checkpoint": {
      "type": "object",
      "description": "Whole-cellview backup taken before the apply edited anything (a timestamped sibling view), recoverable beyond the param-level rollback.",
      "required": ["view"],
      "properties": {
        "view": { "type": "string", "description": "The checkpoint cellview view name." },
        "created_at": { "type": "string", "description": "ISO-8601 timestamp" }
      }
    }
  },
  "$defs": {
    "cellview": {
      "type": "object",
      "required": ["lib", "cell", "view"],
      "properties": {
        "lib": { "type": "string" },
        "cell": { "type": "string" },
        "view": { "type": "string" }
      },
      "additionalProperties": false
    },
    "param_value": {
      "type": "object",
      "required": ["instance", "param", "value"],
      "properties": {
        "instance": { "type": "string" },
        "param": { "type": "string" },
        "value": { "type": ["string", "number"] }
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "description": "Object tallies of a layout cellview.",
      "properties": {
        "shapes": { "type": "integer" },
        "vias": { "type": "integer" },
        "instances": { "type": "integer" }
      }
    },
    "geometry": {
      "type": "object",
      "properties": {
        "before_counts": { "$ref": "#/$defs/counts" },
        "after_counts": { "$ref": "#/$defs/counts" },
        "changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/geometry_change" }
        }
      }
    },
    "geometry_change": {
      "type": "object",
      "required": ["kind", "subject"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["shapeAdded", "shapeRemoved", "shapeModified",
                   "instMoved", "instReoriented", "viaAdded", "viaRemoved"],
          "description": "shapeModified = same shape, changed bbox (moved/resized)."
        },
        "subject": { "type": "string", "description": "Layer (for shapes/vias) or instance name." },
        "detail": { "type": "string" }
      }
    }
  }
}
