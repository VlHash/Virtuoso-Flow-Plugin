{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context.schema.json",
  "title": "VFP Design Context",
  "description": "Current schematic / ADE context exported from the Virtuoso Flow Plugin to VFP Tunnel (RPC: design.context.update).",
  "type": "object",
  "required": ["schema_version", "cellview"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "source": { "type": "string" },
    "timestamp": { "type": "string", "description": "ISO-8601 timestamp" },
    "cellview": { "$ref": "#/$defs/cellview" },
    "instances": { "type": "array", "items": { "$ref": "#/$defs/instance" } },
    "ports": { "type": "array", "items": { "$ref": "#/$defs/port" } },
    "nets": { "type": "array", "items": { "$ref": "#/$defs/net" } },
    "connectivity_risks": {
      "type": "array",
      "description": "Auto-named, unlabeled nets that bear instance terminals. Their names are reassigned by schematic check after any rewiring, so consumers must not key on them. Pin with vfpPinNetLabel to clear.",
      "items": { "$ref": "#/$defs/connectivity_risk" }
    },
    "tb_lint": {
      "type": "array",
      "description": "Testbench connectivity hazards found by vfpLintTestbench: floating terminals, dead nets, and dangling stimulus sources.",
      "items": { "$ref": "#/$defs/tb_lint_issue" }
    },
    "ade": { "$ref": "#/$defs/ade" },
    "last_result": {
      "type": "object",
      "properties": { "available": { "type": "boolean" } }
    }
  },
  "$defs": {
    "cellview": {
      "type": "object",
      "required": ["lib", "cell", "view"],
      "properties": {
        "lib": { "type": "string" },
        "cell": { "type": "string" },
        "view": { "type": "string" }
      },
      "additionalProperties": false
    },
    "instance": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "master": { "$ref": "#/$defs/cellview" },
        "params": {
          "type": "object",
          "description": "Device/instance parameters (e.g. w, l, m, nf).",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "nets": {
          "type": "object",
          "description": "Terminal name -> connected net name.",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "port": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "direction": { "type": "string", "enum": ["input", "output", "inputOutput", "switch", "jumper", "unused"] }
      }
    },
    "net": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "sigType": { "type": "string" }
      }
    },
    "connectivity_risk": {
      "type": "object",
      "required": ["net", "kind"],
      "properties": {
        "net": { "type": "string", "description": "The at-risk net name." },
        "kind": { "type": "string", "enum": ["auto_net"], "description": "Why the net is fragile (auto_net = auto-named, unlabeled)." },
        "terminals": {
          "type": "array",
          "description": "Instance terminals (inst.term) connected to this net.",
          "items": { "type": "string" }
        }
      }
    },
    "tb_lint_issue": {
      "type": "object",
      "required": ["kind", "subject"],
      "properties": {
        "kind": { "type": "string", "enum": ["floatingTerm", "danglingSource"], "description": "floatingTerm = terminal wired to nothing; danglingSource = the same on a stimulus source." },
        "subject": { "type": "string", "description": "The offending instance terminal, as inst.term." },
        "net": { "type": ["string", "null"], "description": "The degenerate net the terminal sits on, or null when unwired." }
      }
    },
    "ade": {
      "type": "object",
      "properties": {
        "available": { "type": "boolean" },
        "active_test": { "type": ["string", "null"] },
        "tests": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
